{
  "description": "Python plugin hooks for context detection and test automation",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/detect-python-version.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "comment": "Script filters internally: only runs pytest for test_*.py or *_test.py files",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pytest-runner.sh",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
